# ─── Trunk Room — environment variables ──────────────────────────────────────
# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit real keys.

# ─── Server-side keys (used by server/index.js) ───────────────────────────────

# remove.bg API key — https://www.remove.bg/dashboard#api-key
# Used by: POST /api/remove-background → server/lib/removeBg.js
REMOVE_BG_API_KEY=

# OpenAI API key — https://platform.openai.com/api-keys
# Used by: POST /api/analyze-clothing  → server/lib/analyzeClothing.js
# Model: gpt-4o (structured JSON output)
OPENAI_API_KEY=

# Optional: Express server port (default 3001)
# API_PORT=3001

# ─── Client-side Vite vars (prefix VITE_) ────────────────────────────────────

# Set to "true" to enable real AI API calls from aiService.js
# When false (default), aiService.js uses mock implementations
# VITE_AI_ENABLED=false

# Override the API base URL if server runs on a different port
# VITE_AI_BASE_URL=http://localhost:3001

# ─── Future weather API (when replacing Open-Meteo) ─────────────────────────
# If you switch to a paid weather provider (OpenWeatherMap, WeatherAPI.com, etc.)
# add the key here and update src/hooks/useWeather.js → fetchFromOpenMeteo()
# WEATHER_API_KEY=
# WEATHER_PROVIDER_URL=https://api.openweathermap.org/data/2.5

# ─── Future AI endpoints (when building server/lib/ modules) ─────────────────
# POST /api/recommend-outfit   → outfit recommendation with GPT-4o
# POST /api/search-closet      → natural language closet search with embeddings
# POST /api/style-suggestions  → personalized style advice with GPT-4o
# See: src/services/ai/aiService.js for interface definitions
