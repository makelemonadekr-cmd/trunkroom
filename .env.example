# ─── Trunk Room — environment variables ──────────────────────────────────────
# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit real keys.

# remove.bg API key — https://www.remove.bg/dashboard#api-key
REMOVE_BG_API_KEY=

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: Express server port (default 3001)
# API_PORT=3001
